APP_NAME="TMail"
APP_ENV=production
APP_KEY=base64:q7kNn0gpU+07DLyLr9lSnpkEm074PIgEwWu4ffxqvuM=
APP_DEBUG=true
APP_URL=""
APP_DEMO=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE=""
DB_USERNAME=""
DB_PASSWORD=""

SESSION_DRIVER="file"
SESSION_LIFETIME=43800
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ENABLE_TMAIL_LOGS=false
API_REQUEST_LIMIT=60

# TMail Performance Optimization
# Enable/disable optimization features (default: all enabled for best performance)
TMAIL_ENABLE_UNSEEN_FILTER=true
TMAIL_ENABLE_LAZY_LOAD=true
TMAIL_ENABLE_PAGINATION=true
TMAIL_PAGINATION_LIMIT=20
TMAIL_ENABLE_DOMAIN_CACHE=true
TMAIL_ENABLE_MEMORY_BYPASS=true
TMAIL_ENABLE_BATCH_INLINE=true
